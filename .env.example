# Google AI (기본 gemini-3.1-pro-preview — Search grounding·Thinking / 신규 키는 gemini-2.0-flash 미지원)
GOOGLE_GENERATIVE_AI_API_KEY=
# Thinking 지원 Pro(권장). Flash/Lite로 바꿀 경우 GEMINI_THINKING=false 필요.
GEMINI_ANALYSIS_MODEL_ID=gemini-3.1-pro-preview
# 선택: 1회 분석에 넣는 본문 최대 글자 수(기본 200000, 약 1분 내외 목표). 초과 시 자동 구간 분할.
# 20000 ~ 400000
# ANALYSIS_MODEL_MAX_INPUT_CHARS=200000
# 선택: Gemini+검색 도구 루프 최대 스텝(기본 40). 늘리면 긴 검색 루프 후 JSON 출력 여유.
# (단일 호출 레거시 경로 ANALYSIS_DISABLE_SPLIT_PHASE=true 일 때만 사용)
# 8 ~ 64
# ANALYSIS_GENERATE_MAX_STEPS=40
# 심층 점검(4단계) 전용 — 미설정 시 ANALYSIS_* 보조, 둘 다 없으면 기본 16스텝(Vercel 60초 한도 대응).
# 8 ~ 64
# DEEP_INSPECTION_GENERATE_MAX_STEPS=16
# 심층 점검 2단계 Google Search 최대 횟수(미설정 시 ANALYSIS_MAX_SEARCH_QUERIES, 둘 다 없으면 4).
# 1 ~ 20
# DEEP_INSPECTION_MAX_SEARCH_QUERIES=4
# 검색(1단계)과 JSON 합성(2단계) 분리 파이프라인 사용(기본: 분리 사용). true면 예전 단일 호출로 되돌림.
# ANALYSIS_DISABLE_SPLIT_PHASE=false
# 1단계 검색 전용 최대 스텝(기본 22). prepareStep으로 검색 횟수 상한 도달 후 텍스트만 유도.
# 4 ~ 48
# ANALYSIS_SEARCH_MAX_STEPS=22
# 누적 Google Search 호출 상한(프롬프트·prepareStep과 동일 숫자 권장). 초과 시 toolChoice=none.
# 1 ~ 20
# ANALYSIS_MAX_SEARCH_QUERIES=8
# 긴 문서(구간 분할)일 때 구간마다 검색(비용↑). false면 첫 구간 검색 요약만 공유.
# ANALYSIS_CHUNK_SEPARATE_SEARCH=false
# Google 정책 완화: 이메일·전화 등 정규식 + (민감 키워드 시) LLM 비식별. true면 정규식만.
# ANALYSIS_DISABLE_POLICY_PREPROCESS=false
# true면 프로덕션에서도 검색 정리 요약(미리보기·URL 개수)을 서버 로그에 남김. 개인정보·URL 유출 주의.
# ANALYSIS_DEBUG_SEARCH_NOTES=false
# 민감 키워드가 없어도 LLM 비식별 1회 실행(디버그)
# ANALYSIS_POLICY_PREPROCESS_FORCE=0
# 선택: 1차 응답이 완전히 비었을 때 같은 요청 재시도 횟수(기본 2). 0이면 재시도 안 함.
# 0 ~ 3
# ANALYSIS_GENERATE_EMPTY_RETRY=2
# true면 검색 본문 비었을 때의 도구 없는 폴백 분석을 끔(디버그용).
# ANALYSIS_DISABLE_NO_TOOL_FALLBACK=false
# 다른 모델로 바꿀 때만 위 GEMINI_ANALYSIS_MODEL_ID 를 주석 처리하고 아래 중 하나(Thinking 미지원 → GEMINI_THINKING=false).
# GEMINI_ANALYSIS_MODEL_ID=gemini-3-flash-preview
# GEMINI_ANALYSIS_MODEL_ID=gemini-2.5-flash
# GEMINI_ANALYSIS_MODEL_ID=gemini-2.5-flash-lite
#
# 사고(Thinking) — @ai-sdk/google thinkingConfig (Gemini 3 권장). 끄기: GEMINI_THINKING=false
# GEMINI_THINKING_LEVEL=high
# (minimal | low | medium | high)

# Unstructured (PDF fallback extraction)
UNSTRUCTURED_API_KEY=
# Optional override (default: https://api.unstructuredapp.io/general/v0/general)
# UNSTRUCTURED_API_URL=
# 스캔 PDF·레이아웃 복잡 문서: hi_res 또는 ocr_only (미설정 시 API 기본, 보통 auto)
# UNSTRUCTURED_PARTITION_STRATEGY=hi_res
# OCR 언어(예: 한글+영문). Unstructured 문서의 languages 형식에 맞게
# UNSTRUCTURED_OCR_LANGUAGES=kor+eng

# Evidence 링크 복구: 직접 fetch 실패 시 Wayback → Serper 순 (Serper는 선택)
# Serper (https://serper.dev) — 없으면 3단계 검색 폴백 생략
# SERPER_API_KEY=
# 서버 로그에 단계별 ms 출력 (resolve-evidence-url)
# RESOLVE_URL_LOG_MS=false

# Vercel `/api/analyze` 최대 실행 시간(초). Pro 10~300, Hobby는 플랫폼 상한 60까지. 미설정 시 300.
# ANALYZE_ROUTE_MAX_DURATION_SEC=300

# Upstash Redis — 설정 시 extract/analyze API에 rate limit 적용 (미설정 시 제한 없음)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# 분당 허용 횟수 (기본: 추출 30, 분석 8)
# RATE_LIMIT_EXTRACT_PER_MIN=30
# RATE_LIMIT_ANALYZE_PER_MIN=8

# Supabase (서버 전용 Service Role — 클라이언트에 넣지 마세요)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 원문 전체를 DB에 저장 (개인정보·저작권 주의). 권장: false
STORE_DOCUMENT_SOURCE_TEXT=false
# 레거시 이름 — true 이면 위와 동일하게 원문 저장으로 간주
# STORE_VERIFICATION_SOURCE_TEXT=false

# Microsoft Clarity: 프로젝트 ID는 app/layout.tsx 의 MS_CLARITY_BOOTSTRAP 에서 변경.
# 로컬(npm run dev)에서는 스크립트를 넣지 않아 콘솔 경고를 막습니다. 프로덕션 빌드에서만 로드됩니다.
