# Dify Workflow (서버 전용 — .env.local 에 복사 후 값 입력)
DIFY_API_KEY=

# 선택: 클라우드 기본값 https://api.dify.ai/v1 , 자체 호스트면 해당 v1 URL
DIFY_API_BASE_URL=https://api.dify.ai/v1

# 워크플로에서 파일을 받는 입력 변수 이름 (Dify 앱 설정과 동일해야 함)
DIFY_WORKFLOW_FILE_INPUT_KEY=pdf

# 파일 종류: document | image | audio | video | custom (PDF는 보통 document)
DIFY_WORKFLOW_FILE_TYPE=document

# API 라우트에서 user 미전달 시 기본값 (업로드/워크플로 user 일치 필요)
DIFY_DEFAULT_USER_ID=anonymous
